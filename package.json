{
    "name":  "mmorpg-browser",
    "version":  "1.0.0",
    "description":  "Simple Browser MMORPG Prototype",
    "main":  "server/server.js",
    "scripts":  {
                    "start":  "node server/server.js",
                    "art:apply":  "node scripts/apply-art-pipeline.js --input art/generated",
                    "art:dry":  "node scripts/apply-art-pipeline.js --input art/generated --dry-run",
                    "assets:optimize":  "node scripts/optimize-images.js"
                },
    "dependencies":  {
                         "cors":  "^2.8.5",
                         "express":  "^4.18.2",
                         "sqlite3":  "^5.1.6"
                     },
    "devDependencies":  {
                            "playwright":  "^1.58.2",
                            "sharp":  "^0.34.5"
                        }
}
