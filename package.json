{
    "name": "mmorpg-browser",
    "version": "0.3.5.2",
    "description": "Advanced Browser MMORPG with Complete Gameplay Systems - v0.3.5.2v: IA Básica dos Mobs Implementada",
    "main": "server/server.js",
    "scripts": {
        "start": "node server/server.js",
        "dev": "nodemon server/server.js",
        "art:apply": "node scripts/apply-art-pipeline.js --input art/generated",
        "art:dry": "node scripts/apply-art-pipeline.js --input art/generated --dry-run",
        "assets:optimize": "node scripts/optimize-images.js",
        "error:log": "node scripts/generateErrorLog.js",
        "git:ensure": "node scripts/ensure-gitignore.js",
        "test": "jest",
        "lint": "eslint server/**/*.js",
        "docs": "jsdoc -c jsdoc.conf.json"
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "lodash": "^4.17.21",
        "moment": "^2.29.4",
        "socket.io": "^4.7.4",
        "socket.io-client": "^4.8.3",
        "sqlite3": "^5.1.6",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "eslint": "^8.55.0",
        "jest": "^29.7.0",
        "jsdoc": "^4.0.2",
        "jsdom": "^28.1.0",
        "nodemon": "^3.0.2",
        "playwright": "^1.58.2",
        "sharp": "^0.34.5",
        "supertest": "^6.3.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=16.0.0"
    },
    "keywords": [
        "mmorpg",
        "browser",
        "game",
        "multiplayer",
        "socket.io",
        "nodejs",
        "javascript"
    ],
    "author": "MMORPG Browser Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/your-username/mmorpg-browser.git"
    }
}
